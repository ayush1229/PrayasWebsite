# Sample environment variables for the server
# Copy this file to `.env` and fill in real values before running.

# Application
NODE_ENV=development
PORT=5000

# MongoDB connection string. Prefer a full URI (includes username/password if needed).
# Example: mongodb://localhost:27017/prayas
MONGO_URI=mongodb://localhost:27017/prayas

# Alternatively, you can provide a cloud URI:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/mydbname?retryWrites=true&w=majority

# Optional separate credentials (if your setup requires them instead of embedding in URI)
# MONGO_USER=
# MONGO_PASS=

# Other optional keys used by the app
# JWT_SECRET=your_jwt_secret
# SENTRY_DSN=
